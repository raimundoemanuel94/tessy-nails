rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth()       { return request.auth != null; }
    function uid()          { return request.auth.uid; }
    function isSuperAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(uid())).data.role == "superadmin";
    }
    // isOwner: usa uid()==sid (studioId == ownerId neste sistema)
    // Evita get() em doc inexistente que causa permission-denied
    function isOwner(sid)   { return isAuth() && uid() == sid; }

    // ── /users/{uid} ──────────────────────────────────────────────
    match /users/{userId} {
      allow read:   if isAuth() && (uid() == userId || isSuperAdmin());
      allow create: if isAuth() && uid() == userId;
      allow update: if isAuth() && (uid() == userId || isSuperAdmin());
      allow delete: if isSuperAdmin();
    }

    // ── /studios/{studioId} ───────────────────────────────────────
    match /studios/{studioId} {
      allow read:   if isAuth() && (isOwner(studioId) || isSuperAdmin());
      allow create: if isAuth();
      allow update: if isAuth() && (isOwner(studioId) || isSuperAdmin());
      allow delete: if isSuperAdmin();

      match /services/{serviceId} {
        allow read:  if isAuth();
        allow write: if isOwner(studioId) || isSuperAdmin();
      }

      match /appointments/{apptId} {
        allow read:  if isAuth() && (
          isOwner(studioId) || isSuperAdmin() ||
          resource.data.clientId == uid()
        );
        allow create: if isAuth();
        allow update: if isAuth() && (
          isOwner(studioId) || isSuperAdmin() ||
          resource.data.clientId == uid()
        );
        allow delete: if isOwner(studioId) || isSuperAdmin();
      }

      match /clients/{clientId} {
        allow read, write: if isOwner(studioId) || isSuperAdmin();
      }

      match /settings/{doc} {
        allow read:  if isAuth();
        allow write: if isOwner(studioId) || isSuperAdmin();
      }
    }

    // ── legado global ─────────────────────────────────────────────
    match /clients/{clientId}     { allow read, write: if isAuth(); }
    match /appointments/{apptId}  { allow read, write: if isAuth(); }
    match /services/{serviceId}   { allow read, write: if isAuth(); }
    match /settings/{doc}         { allow read, write: if isAuth(); }
  }
}
