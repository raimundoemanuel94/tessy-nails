rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Funções helpers ──────────────────────────────────────────
    function isAuth()        { return request.auth != null; }
    function uid()           { return request.auth.uid; }
    function userRole()      {
      return get(/databases/$(database)/documents/users/$(uid())).data.role;
    }
    function isSuperAdmin()  { return isAuth() && userRole() == "superadmin"; }
    function isOwner(sid)    {
      return isAuth() &&
        get(/databases/$(database)/documents/studios/$(sid)).data.ownerId == uid();
    }

    // ── /users/{uid} ──────────────────────────────────────────────
    match /users/{userId} {
      allow read:   if isAuth() && (uid() == userId || isSuperAdmin());
      allow create: if isAuth() && uid() == userId;
      allow update: if isAuth() && (uid() == userId || isSuperAdmin());
      allow delete: if isSuperAdmin();
    }

    // ── /studios/{studioId} ───────────────────────────────────────
    match /studios/{studioId} {
      allow read:   if isAuth() && (isOwner(studioId) || isSuperAdmin());
      allow create: if isAuth();
      allow update: if isAuth() && (isOwner(studioId) || isSuperAdmin());
      allow delete: if isSuperAdmin();

      // Serviços — owner escreve, clientes leem
      match /services/{serviceId} {
        allow read:   if isAuth();
        allow write:  if isOwner(studioId) || isSuperAdmin();
      }

      // Agendamentos — owner e o cliente do agendamento
      match /appointments/{apptId} {
        allow read:   if isAuth() && (
          isOwner(studioId) ||
          isSuperAdmin() ||
          resource.data.clientId == uid()
        );
        allow create: if isAuth();
        allow update: if isAuth() && (
          isOwner(studioId) ||
          isSuperAdmin() ||
          resource.data.clientId == uid()
        );
        allow delete: if isOwner(studioId) || isSuperAdmin();
      }

      // Clientes — só o owner e superadmin
      match /clients/{clientId} {
        allow read, write: if isOwner(studioId) || isSuperAdmin();
      }

      // Settings — owner lê/escreve, clientes só leem
      match /settings/{doc} {
        allow read:  if isAuth();
        allow write: if isOwner(studioId) || isSuperAdmin();
      }
    }

    // ── /clients (legado global) — manter leitura para migração ──
    match /clients/{clientId} {
      allow read:  if isAuth();
      allow write: if isAuth();
    }

    // ── /appointments (legado global) ─────────────────────────────
    match /appointments/{apptId} {
      allow read:  if isAuth();
      allow write: if isAuth();
    }

    // ── /services (legado global) ─────────────────────────────────
    match /services/{serviceId} {
      allow read:  if isAuth();
      allow write: if isAuth();
    }

    // ── /settings (legado global) ─────────────────────────────────
    match /settings/{doc} {
      allow read:  if isAuth();
      allow write: if isAuth();
    }
  }
}
